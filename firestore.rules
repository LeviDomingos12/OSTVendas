rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global hardened helper definitions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Rule for all paths: ensure user is authenticated to read/write
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
    
    // --- PORTUGUESE COLLECTIONS ---
    
    match /usuarios/{uid} {
      allow read, write: if isSignedIn();
    }
    
    match /empresas/{empresaId} {
      allow read, write: if isSignedIn();
    }
    
    match /logs/{logId} {
      allow read, write: if isSignedIn();
    }
    
    match /produtos/{produtoId} {
      allow read, write: if isSignedIn();
    }
    
    match /transacoes/{transacaoId} {
      allow read, write: if isSignedIn();
    }
    
    match /settings/{configDoc} {
      allow read, write: if isSignedIn();
    }
  }
}
