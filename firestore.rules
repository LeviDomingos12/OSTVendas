rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Dynamic, segmented access rule: any collection segmented by user's UID (multi-tenant partition)
    match /admins/{uid}/{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == "levidomingos12@gmail.com"
      );
    }

    // Root-level usuarios collection for employee profiles and sync
    match /usuarios/{userId} {
      // Allow authenticated users to read and list user profiles (needed for staff sync/cashier validation)
      allow read: if request.auth != null;
      
      // Allow a user to create/update their own profile, or verified admin to write
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == "levidomingos12@gmail.com"
      );
    }

    // Publicly readable configuration rules
    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
