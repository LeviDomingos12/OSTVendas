rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Dynamic, segmented access rule: any collection segmented by user's UID.
    // This strictly isolates tenant/user data (e.g., admins/{uid}/..., usuarios/{uid}, logs/{uid}/...)
    // ensuring that authenticated users can only access their own partition.
    match /{collection}/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Publicly readable configuration rules
    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
